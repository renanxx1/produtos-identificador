# IA opcional para comparar se dois anuncios sao o mesmo produto.
# Se nao informar, o projeto usa matching heuristico local.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Custos e impostos. Ajuste conforme seu regime, NCM e operacao real.
BRL_PER_VND=0.00022
IMPORT_TAX_RATE=0.60
ICMS_RATE=0.17
ML_FEE_RATE=0.16
PAYMENT_FEE_RATE=0.0499
FIXED_COST_BRL=12.00
TARGET_MARGIN_RATE=0.25

